{
  "extends": [
    "config:recommended",
    "default:semanticCommits",
    "default:separateMultipleMajorReleases",
    "default:enableVulnerabilityAlerts",
    ":maintainLockFilesMonthly",
    ":dependencyDashboard",
    "group:linters",
    "group:recommended"
  ],
  "schedule": [
    "after 10pm and before 5am every weekday"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "prConcurrentLimit": 2,
  "branchConcurrentLimit": 3,
  "prCreation": "not-pending",
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "devDependencies (non-major)",
      "groupSlug": "dev-dependencies",
      "automerge": true
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "npm packages (non-major)",
      "groupSlug": "npm-non-major",
      "automerge": true
    },
    {
      "matchDatasources": [
        "maven"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "Maven packages (non-major)",
      "groupSlug": "maven-non-major",
      "automerge": true
    },
    {
      "matchDatasources": [
        "gradle"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "Gradle plugins (non-major)",
      "groupSlug": "gradle-non-major",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "schedule": []
    },
    {
      "description": "Disable any intra-module dependency. This is quite an aggressive one, and goes beyond the current repo",
      "enabled": false,
      "matchPackageNames": [
        "/^nl\\.jvandis.*/"
      ]
    }
  ]
}
